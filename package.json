    "startdeck": "tsx src/smoke/startdeck.playtest.ts",
    "lint:content": "tsx src/tools/lint.run.ts",
    "lint:imports": "tsx src/tools/import-boundary.run.ts",
    "coldread": "tsx src/coldread/run.ts",
    "coldread:sample": "tsx src/coldread/sample.ts",
    "coldread:loop": "tsx src/coldread/loop-relay.ts",
    "coldread:loop-sample": "tsx src/coldread/loop-sample.ts",
    "typecheck": "tsc --noEmit",
    "bots": "tsx src/bots/run.ts"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
